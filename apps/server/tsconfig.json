{
  "extends": "@monorepo/tsconfig/express.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDirs": ["./src", "../../packages/utils/src"],
    "skipLibCheck": true,
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "paths": {
      "@/*": ["./*"],
      "@monorepo/utils": ["../../packages/utils/src/index.ts"],
      "@monorepo/utils/*": ["../../packages/utils/src/*"]
    }
  },
  "include": ["src/**/*.ts", "eslint.config.mjs"],
  "exclude": ["node_modules", "dist", "prisma.config.ts"]
}