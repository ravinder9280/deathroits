{
  "extends": "@monorepo/tsconfig/express.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "skipLibCheck": true,
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["src/**/*.ts", "eslint.config.mjs"],
  "exclude": ["node_modules", "dist", "prisma.config.ts"]
}